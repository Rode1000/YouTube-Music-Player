{
  "name": "youtube-music-player",
  "version": "1.8.0",
  "description": "YouTube Music Player",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/nubsuki/YouTube-Music-Player"
  },
  "scripts": {
    "start": "electron .",
    "build:all": "electron-builder --linux --win",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "youtube",
    "music",
    "player",
    "electron",
    "desktop",
    "audio",
    "streaming",
    "youtube-music",
    "music-player",
    "media-player"
  ],
  "author": {
    "name": "nubsuki",
    "email": "nubsuki@proton.me"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "electron": "^38.1.2",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.nubsuki.youtubemusic",
    "productName": "YouTube Music",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "nubsuki",
      "repo": "YouTube-Music-Player"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "YouTube Music",
      "artifactName": "YouTube-Music-Setup-${version}.${ext}"
    },
    "linux": {
      "maintainer": "nubsuki <nubsuki@proton.me>",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Audio"
    }
  },
  "dependencies": {
    "@gorhill/ubo-core": "^0.1.30",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.6.2",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.5"
  }
}
